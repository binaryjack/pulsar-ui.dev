{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@synetics/design-tokens": ["../synetics-design-system/dist/src/index.d.ts"],
      "@synetics/design-tokens/*": ["../synetics-design-system/dist/src/*"],
      "@synetics/synetics.dev": ["../synetics.dev/dist/index.d.ts"],
      "@synetics/synetics.dev/*": ["../synetics.dev/dist/*"],
      "@synetics/formular.dev": ["../formular.dev/dist/types/formular-dev.es.d.ts"],
      "@synetics/formular.dev/*": ["../formular.dev/dist/types/*"]
    }
  },
  "files": [
    "../synetics.dev/src/types/jsx.d.ts",
    "../synetics.dev/src/types/psr-modules.d.ts",
    "src/css.d.ts",
    "src/types/psr-modules.d.ts"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.syn",
    "src/**/*.type.ts",
    "src/**/*.interface.ts",
    "src/**/*.enum.ts",
    "../synetics.dev/pulsar.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
