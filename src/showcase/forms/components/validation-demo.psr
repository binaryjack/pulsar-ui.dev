/**
 * Validation Demo
 * Schema validators (min/email/number range) — FieldValidation auto-rendered inside TextField
 */

import { createSignal, onCleanup } from '@pulsar-framework/pulsar.dev';
import { createForm, f } from '@pulsar-framework/formular.dev';
import type { IFormular } from '@pulsar-framework/formular.dev';
import { FormProvider, TextField } from '@/components/formular';

export component ValidationDemo() {
  const [form, setForm] = createSignal<IFormular<{ password: string; age: number }> | null>(null);

  createForm({
    schema: f.object({
      password: f.string().min(8).nonempty().debounce(200),
      age: f.number().min(18).max(120),
    }),
    defaultValues: { password: '', age: 0 },
  }).then(setForm);

  onCleanup(() => form()?.clear());

  const [isValid, setIsValid] = createSignal<boolean | null>(null);

  const handleValidateAll = async () => {
    const result = await form()?.validateForm();
    setIsValid(result ?? false);
  };

  return (
    <div class="demo-card">
      <h3 class="demo-title">2️⃣ Schema Validators</h3>
      <p class="demo-desc">
        <code>f.string().min(8)</code> / <code>f.number().min(18).max(120)</code>.
        <code>FieldValidation</code> auto-rendered inside <code>TextField</code>. Debounce: 200ms.
      </p>

      {!form() ? (
        <p class="status-loading">⏳ Initialising form engine…</p>
      ) : (
        <FormProvider form={form()!} onSaveCallback={() => {}} onQuitCallback={() => {}}>
          <TextField name="password" label="Password (min 8 chars)" showErrors={true} showGuides={true} />
          <TextField name="age" label="Age (18–120)" showErrors={true} showGuides={true} />

          <button class="submit-btn" onClick={handleValidateAll}>
            🔍 Validate All
          </button>

          {isValid() !== null ? (
            <p class={isValid() ? 'status-ok' : 'status-fail'}>
              {isValid() ? '✅ All fields valid' : '❌ Form has errors'}
            </p>
          ) : null}
        </FormProvider>
      )}
    </div>
  );
}
